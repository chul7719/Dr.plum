// [기능] 마트 설비 유지보수 매칭 플랫폼 - 데이터 모델
// PostgreSQL(Neon)을 사용합니다. enum을 지원하는 커넥터라 role/status
// 필드는 아래처럼 실제 `enum`으로 선언해 DB 레벨에서도 허용값을 제한합니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MART_MANAGER // 매장 담당자
  TECHNICIAN // 협력업체 기사
  HQ_ADMIN // 본사 관리자
}

enum RequestStatus {
  QUOTING // 견적(입찰) 대기 - 협력업체들이 가격/도착예정시간을 제안하는 단계
  ACCEPTED // 업체 선정 완료 - 아직 기사가 출발 전
  IN_PROGRESS // 기사 출발 ~ 현장 수리 중 (세부 단계는 TimelineEvent 개수로 구분)
  COMPLETED // 완료보고 제출 (정산 전)
  PAID // 정산 완료
}

enum SettlementStatus {
  PENDING // 정산 대기
  INVOICED // 청구서 발행
  PAID // 지급 완료
}

// [기능] 다지점/다본사 구조 (README 로드맵 5)
// 하나의 프랜차이즈 본사가 여러 지점(Store)을 가지는 구조를 표현합니다.
// HQ_ADMIN 계정은 특정 Organization에 소속되고, 대시보드/정산 조회는 항상
// "내 Organization에 속한 Store"로 범위를 제한합니다 (다른 프랜차이즈 데이터 격리).
model Organization {
  id             String          @id @default(cuid())
  name           String
  stores         Store[]
  admins         User[]
  vendors        Vendor[]
  equipmentTypes EquipmentType[]
  notices        Notice[]
  createdAt      DateTime        @default(now())
}

model Store {
  id             String       @id @default(cuid())
  name           String
  address        String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  users          User[]
  requests       Request[]
  createdAt      DateTime     @default(now())
}

// [기능] 협력업체 - 두 가지 방식으로 생겨납니다.
//   1) 기사 회원가입 시 "새 업체 등록" (organizationId 없음) - 모든 본사의 요청에
//      입찰 가능한 공용 마켓플레이스 업체
//   2) 본사가 직접 "업체 등록" 화면에서 등록 (organizationId 있음) - 그 본사
//      소속 매장의 요청에만 입찰 가능한 본사 전용 업체
model Vendor {
  id             String        @id @default(cuid())
  name           String
  ratingAvg      Float         @default(4.5)
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  technicians    User[]
  quotes         Quote[]
  createdAt      DateTime      @default(now())
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String
  role         Role

  // MART_MANAGER 인 경우에만 사용
  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String?

  // TECHNICIAN 인 경우에만 사용
  vendor   Vendor? @relation(fields: [vendorId], references: [id])
  vendorId String?

  // HQ_ADMIN 인 경우에만 사용 (다지점/다본사 구조에서 소속 프랜차이즈 본사 구분)
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  requests  Request[] @relation("RequestedBy")
  createdAt DateTime  @default(now())
}

// [기능] 설비 종류 관리 - 본사가 관리하는 "요청 등록 시 고를 수 있는 설비 종류"
// 목록입니다. 예전에는 NewRequestForm에 냉장 쇼케이스/냉동고/공조 설비/POS
// 단말이 하드코딩돼 있었는데, 이제 본사가 자기 소속 매장에서 쓸 목록을
// 직접 추가·삭제할 수 있습니다. Request.equipmentType은 여전히 자유
// 텍스트(String)라 이 목록은 입력을 돕는 선택지일 뿐, 요청과 FK로 묶여있진
// 않습니다.
model EquipmentType {
  id             String       @id @default(cuid())
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
}

// [기능] 본사 공지사항 게시판 - 그 본사 소속 매장 담당자 + 협력업체 기사에게
// 공통으로 보여주는 공지입니다 (README: "본사 소속 매장+기사 전체 공통 게시판").
model Notice {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  title          String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Request {
  id            String @id @default(cuid())
  store         Store  @relation(fields: [storeId], references: [id])
  storeId       String
  requestedBy   User   @relation("RequestedBy", fields: [requestedById], references: [id])
  requestedById String

  equipmentType String // 예: 냉장 쇼케이스, 공조 설비, POS 단말
  symptom       String
  urgent        Boolean       @default(false)
  status        RequestStatus @default(QUOTING)

  quotes          Quote[] @relation("RequestQuotes")
  selectedQuote   Quote?  @relation("SelectedQuote", fields: [selectedQuoteId], references: [id])
  selectedQuoteId String? @unique

  // [기능] 완료보고 - 협력업체 기사가 작업 완료 시 남기는 조치 내용 + 사진(들)
  completionNotes String?
  photos          CompletionPhoto[]

  timelineEvents TimelineEvent[]
  review         Review?
  settlement     Settlement?

  createdAt DateTime @default(now())
}

// [기능] 협력업체 실제 입찰 흐름 (README 로드맵 1)
// 요청 1건에 여러 협력업체가 각자 가격/방문 예정 일시를 제안(Quote)하고,
// 매장 담당자가 그중 하나를 선택합니다. 업체당 요청 1건에 제안은 1개만
// 유지되도록(재제안 시 갱신) @@unique 제약을 둡니다.
model Quote {
  id          String   @id @default(cuid())
  request     Request  @relation("RequestQuotes", fields: [requestId], references: [id])
  requestId   String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  vendorId    String
  price       Int // 원
  // [기능] 기사가 제안하는 방문 예정 일시(날짜+시간, 기본값: 오늘 현재 시각).
  // 화면에서는 오늘이면 "N분 후 도착"으로 계산해서, 다른 날짜면 날짜+시각을
  // 그대로 보여줍니다 (src/lib/format.ts의 fmtArrival 참고).
  scheduledAt DateTime @default(now())
  note        String? // 기사가 남기는 제안 메모 (예: "부품 재고 있음, 즉시 출발 가능")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  selectedFor Request? @relation("SelectedQuote")

  @@unique([requestId, vendorId])
}

model TimelineEvent {
  id         String   @id @default(cuid())
  request    Request  @relation(fields: [requestId], references: [id])
  requestId  String
  step       String // 요청 접수 / 기사 출발 / 현장 도착·점검 / 수리 완료 / 정산·리뷰
  occurredAt DateTime @default(now())
}

// [기능] 사진 업로드 (README 로드맵 2)
// 완료보고 시 기사가 첨부하는 현장 사진들입니다. 지금은 데모 단계라 base64
// data URL을 그대로 저장합니다. 실제 서비스로 전환할 때는 dataUrl 대신
// S3/Cloudflare R2에 업로드한 결과 URL을 저장하도록 이 모델만 바꾸면 됩니다.
model CompletionPhoto {
  id        String   @id @default(cuid())
  request   Request  @relation(fields: [requestId], references: [id])
  requestId String
  dataUrl   String
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  request   Request  @relation(fields: [requestId], references: [id])
  requestId String   @unique
  stars     Int
  text      String?
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())
}

// 정산: 매장이 지불한 금액 중 플랫폼 수수료와 협력업체 지급액을 분리해 관리합니다.
model Settlement {
  id               String           @id @default(cuid())
  request          Request          @relation(fields: [requestId], references: [id])
  requestId        String           @unique
  amount           Int // 매장 결제 금액 (총액)
  commissionRate   Float            @default(0.1) // 플랫폼 수수료율
  commissionAmount Int // 플랫폼 수수료 (원)
  payoutAmount     Int // 협력업체 지급액 (원) = amount - commissionAmount
  status           SettlementStatus @default(PENDING)
  // [기능] 결제/PG 연동 인터페이스 (README 로드맵 4, src/lib/payment.ts)
  // 실제 PG 연동 전까지는 MockPaymentGateway가 채워주는 가짜 거래번호입니다.
  transactionId    String?
  paidAt           DateTime?
  createdAt        DateTime         @default(now())
}
